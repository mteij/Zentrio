# ──────────────────────────────────────────────────────────────────────────────
# Zentrio — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy to .env in the REPOSITORY ROOT (not app/) and fill in the values.
# Lines beginning with # are comments; uncomment to enable.

# ─── Required ─────────────────────────────────────────────────────────────────

# Auth secret — used for signing session tokens.
# Generate:  openssl rand -base64 32
AUTH_SECRET="change-me"

# Encryption key — used for encrypting sensitive data at rest (min 32 chars).
# Generate:  openssl rand -hex 32
ENCRYPTION_KEY="change-me"

# TMDB API key — required for media metadata (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────

PORT=3000
APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:5173
DATABASE_URL=./data/zentrio.db
NODE_ENV=development

# ─── Email ────────────────────────────────────────────────────────────────────
# Pick ONE option. Leave all commented out to disable email entirely.

# Option A — SMTP
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=you@gmail.com
# EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
# EMAIL_FROM=noreply@example.com

# Option B — SMTP connection URL (alternative to individual fields)
# SMTP_URL=smtp://user:pass@smtp.example.com:587

# Option C — Resend (https://resend.com — free tier: 3 000 emails/month)
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Provider selection: auto | smtp | resend  (auto = Resend if configured, else SMTP)
# EMAIL_PROVIDER=auto

# ─── SSO Providers ────────────────────────────────────────────────────────────

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# Generic OpenID Connect
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_ISSUER=
# OIDC_DISPLAY_NAME=OpenID

# ─── Admin ────────────────────────────────────────────────────────────────────

# Enable the admin console. Navigate to /admin while logged in to claim superadmin.
ADMIN_ENABLED=true

# Optional token required to claim initial superadmin during setup.
# When set, the setup form requires this token before granting superadmin.
# If unset, any authenticated user can claim on a fresh (no-owner) instance.
# Generate:  openssl rand -hex 24
# ADMIN_SETUP_TOKEN=

# Collect aggregate platform/browser statistics shown in the admin dashboard.
# Automatically disabled when ADMIN_ENABLED=false. Set to false to opt out
# while keeping the admin console on. Only aggregate counts are ever shown —
# no individual user data is exposed in the UI.
# Note: Better Auth always stores userAgent on sessions as part of its own session
# management; this only controls Zentrio's aggregation (session_client_hints table).
# ANALYTICS_ENABLED=true

# Step-up verification validity for sensitive admin actions (minutes)
# STEP_UP_MAX_AGE_MINUTES=10

# ─── Integrations ─────────────────────────────────────────────────────────────

# Trakt (https://trakt.tv/oauth/applications)
# TRAKT_CLIENT_ID=
# TRAKT_CLIENT_SECRET=

# Fanart.tv (https://fanart.tv/get-an-api-key/)
# FANART_API_KEY=

# IMDB ratings refresh interval (hours)
# IMDB_UPDATE_INTERVAL_HOURS=24

# ─── Tuning ───────────────────────────────────────────────────────────────────

# Rate limiting (set both to 0 to disable)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_LIMIT=100

# Logging
# LOG_LEVEL=info                 # debug | info | warn | error
# PROXY_LOGS=true                # Hono request logger (the --> / <-- lines)

# Email transport timeouts (ms)
# EMAIL_SMTP_TIMEOUT_MS=8000
# EMAIL_SEND_TIMEOUT_MS=10000
# EMAIL_PROVIDER_BACKOFF_MS=300000
