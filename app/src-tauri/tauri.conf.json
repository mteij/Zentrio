{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zentrio",
  "version": "0.7.6",
  "identifier": "com.zentrio.mteij",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zentrio",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "url": "/",
        "decorations": false,
        "transparent": true,
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; connect-src * data: blob: ws: wss:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https: asset: http://asset.localhost; worker-src 'self' blob:; media-src 'self' https: blob: asset: http://asset.localhost; font-src 'self' https://fonts.gstatic.com",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/zentrio/downloads/**/*",
          "$APPLOCALDATA/zentrio/downloads/**/*",
          "$DOWNLOAD/**/*"
        ]
      },
      "capabilities": [
        "default"
      ]
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "deb",
      "rpm",
      "appimage",
      "nsis",
      "app",
      "dmg"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/installer-header.png",
        "sidebarImage": "icons/installer-sidebar.png",
        "installMode": "both",
        "compression": "lzma"
      }
    },
    "macOS": {
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": {
          "width": 540,
          "height": 380
        },
        "appPosition": {
          "x": 130,
          "y": 180
        },
        "applicationFolderPosition": {
          "x": 410,
          "y": 180
        }
      }
    },
    "externalBin": [
      "bin/zentrio-server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "deep-link": {
      "mobile": [
        {
          "scheme": [
            "zentrio"
          ],
          "appLink": false
        }
      ],
      "desktop": {
        "schemes": [
          "zentrio"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://zentrio.eu/updater?current_version={{current_version}}&target={{target}}&arch={{arch}}"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI1QjA2NDNENzYxMERGOTcKUldTWDN4QjJQV1N3SllUNTlKbmFKTjh1cVJ1R1F0bW1xUFhXbTVwY08xOVdQdDZGNXdjektWZ0MK"
    }
  }
}
